//-------------------------------------------------------------------------
// Enum Info: {{namespace}} {{typeName}}
//-------------------------------------------------------------------------

#include "Core/TypeSystem/Info/TypeEnumInfo.h"

{{isDevOnlyBegin}}
namespace SE
{
    template<>
    class TTypeEnumInfo<::{{namespace}}{{typeName}}> final : public TypeEnumInfo
    {
    public:
        static TTypeEnumInfo<::{{namespace}}{{typeName}}> * s_pTypeInfo;

        // Static registration Function
        //-------------------------------------------------------------------------
        static void RegisterType()
        {
            ENGINE_ASSERT(s_pTypeInfo == nullptr);
            s_pTypeInfo = New<TTypeEnumInfo<::{{namespace}}{{typeName}}>>();

            Types::RegisterEnum(s_pTypeInfo);
        };

        // Static unregistration Function
        //-------------------------------------------------------------------------
        static void UnregisterType()
        {
            ENGINE_ASSERT(s_pTypeInfo != nullptr);
            Types::UnregisterEnum(s_pTypeInfo);
            Delete(s_pTypeInfo);
        };

        // Constructor
        //-------------------------------------------------------------------------
        TTypeEnumInfo()
        {
            // Create type info
            id = TypeID(SE_TEXT("{{namespace}}{{typeName}}"));
            size = sizeof(::{{namespace}}{{typeName}});
            alignment = alignof(::{{namespace}}{{typeName}});
            name = SE_TEXT("{{typeName}}");
            fullName = SE_TEXT("{{namespace}}{{typeName}}");
            underlyingType = {{underlyingType}};

            TypeEnumInfo::ConstantInfo constantInfo;
            {{#enumConstants}}constantInfo.id = StringID(SE_TEXT("{{enumConstantLabel}}"));
            constantInfo.value = {{enumConstantValue}};
            constantInfo.alphabeticalOrder = {{enumConstantSortedOrder}};
            SE_DEVELOPMENT_ONLY( constantInfo.description = "{{enumConstantEscapedDescription}}");
            constants.Add(constantInfo);
            {{/enumConstants}}
        };
    };

    TTypeEnumInfo<::{{namespace}}{{typeName}}> * TTypeEnumInfo<::{{namespace}}{{typeName}}>::s_pTypeInfo = nullptr;
}
{{isDevOnlyEnd}}